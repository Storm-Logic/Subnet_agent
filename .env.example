# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
ALLOWED_CHANNEL_IDS=123456789,987654321   # leave empty to respond in all channels
ANNOUNCEMENT_CHANNEL_IDS=123456789        # channels where active announcements are auto-posted
ANNOUNCEMENT_POLL_INTERVAL=15             # seconds between announcement checks
TOP_MINER_ALERT_CHANNEL_IDS=123456789     # separate channels for top miner change alerts
TOP_MINER_ALERTS_ENABLED=true             # alert when the on-chain top miner UID changes
TOP_MINER_ALERT_MENTION_EVERYONE=true     # include @everyone in top miner change alerts
TOP_MINER_STARTUP_ALERT_ENABLED=true      # post current top miner to top-miner alert channels on startup

# ── Codex CLI ─────────────────────────────────────────────────────────────────
# Install/login separately with Codex CLI before running the bot.
CODEX_COMMAND=codex
CODEX_MODEL=
CODEX_CREATIVE_MODEL=
CODEX_TIMEOUT=120
CODEX_SANDBOX=read-only
CODEX_APPROVAL_POLICY=never
CODEX_WEB_SEARCH=live
CODEX_BROWSE_ALL_REFERENCE_URLS=true

# ── Bittensor ─────────────────────────────────────────────────────────────────
NETUID=1
SUBTENSOR_NETWORK=finney                  # or "test"
CHAIN_POLL_INTERVAL=300                   # seconds between Bittensor chain cache refreshes

# ── wandb — no run IDs needed, auto-discovered ────────────────────────────────
WANDB_API_KEY=your_wandb_api_key
WANDB_ENTITY=perturb-ai
WANDB_PROJECT=perturb-validator
WANDB_POLL_INTERVAL=120                   # seconds between polls (default 2 min)
WANDB_TARGET_RECORDS=100                  # stop fetching runs once ~100 records collected
WANDB_MAX_RUNS=10                         # hard cap: never fetch more than 10 runs per cycle
WANDB_API_TIMEOUT=60                      # wandb graphql timeout seconds

# ── GitHub docs ───────────────────────────────────────────────────────────────
GITHUB_REPO=0xsigurd/Perturb
GITHUB_TOKEN=
DOCS_PATHS=README.md,docs/               # comma-separated files or folders to include in Codex context

# ── Admin UI ──────────────────────────────────────────────────────────────────
ADMIN_UI_TOKEN=pick_a_strong_token_here   # used to log into the web admin panel
ADMIN_PORT=8888

# ── GitHub webhook (optional) ────────────────────────────────────────────────
WEBHOOK_SECRET=your_github_webhook_secret
WEBHOOK_PORT=8080
